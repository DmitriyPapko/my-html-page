{
  "env": {
    "es2021": true,
    "browser": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 2022
  },
  "ignorePatterns": ["dist/"],
  "rules": {
    "no-unused-vars": "off",
    "no-empty": "off",
    "no-undef": "off"
  }
}
